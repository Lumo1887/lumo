# --- Supabase (Nutzerkonten + Datenbank) ---
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=dein-supabase-service-role-key

# --- Stripe ---
# Diese Werte bekommst du aus deinem Stripe Dashboard (Testmodus zunächst empfohlen).
STRIPE_SECRET_KEY=dein-stripe-secret-key-hier-einfuegen
STRIPE_WEBHOOK_SECRET=dein-stripe-webhook-secret-hier-einfuegen
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=dein-stripe-publishable-key-hier-einfuegen

# Basis-URL deines Deployments (lokal: http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Preis für das Modul "Statistik 1" in Cent (799 = 7,99 EUR)
STATISTIK1_PRICE_CENT=799
